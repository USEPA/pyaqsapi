include README.rst
include *.pyi
include *py.typed

#exclude config files
exclude environment.yml
exclude conda-forge.yaml
exclude mypy.ini
exclude tox.ini
exclude pytest.ini
exclude pyrightconfig.json
exclude codeinventory.json
exclude codemeta.json
exclude .coveragerc
exclude pylint_import-dependency-graph.png
exclude .actrc
exclude .bandit
exclude .coverage
exclude .coveragerc
exclude .dockerignore
exclude .gitattributes
exclude .gitignore

# Exclude common development, build and editor artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
exclude pylint_import-dependency-graph.png

# Prune top-level development, CI, and editor folders
prune .devcontainer/
prune .github/
prune .vscode/
prune .spyproject/
prune .git/
prune .tox/
prune dist/
prune dev/
prune codeql-custom-queries-python/
prune htmlcov/
exclude pyaqsapi.code-workspace
exclude .ruff_cache/
exclude .pytest_cache/
